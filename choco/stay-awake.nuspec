<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.chocolatey.org/2015/06/nuspec.xsd">
  <metadata>
    <id>stay-awake</id>
    <version>0.4.0</version>
    <title>Stay Awake</title>
    <authors>Rodolfo Castelo</authors>
    <owners>shoootyou</owners>
    <projectUrl>https://github.com/shoootyou/stay-awake</projectUrl>
    <licenseUrl>https://github.com/shoootyou/stay-awake/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Keep your computer awake and active. A lightweight tray utility that prevents idle detection using OS-level power assertions and optional mouse jiggling.</description>
    <tags>mouse-jiggler keep-awake anti-idle utility tray</tags>
    <packageSourceUrl>https://github.com/shoootyou/stay-awake</packageSourceUrl>
    <bugTrackerUrl>https://github.com/shoootyou/stay-awake/issues</bugTrackerUrl>
    <summary>Cross-platform mouse jiggler and anti-inactivity tool</summary>
  </metadata>
  <files>
    <file src="tools/**" target="tools" />
  </files>
</package>
