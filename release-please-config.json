{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "src-tauri": {
      "release-type": "rust",
      "include-component-in-tag": false,
      "include-paths": [
        "src",
        "src-tauri",
        "package.json",
        "package-lock.json"
      ],
      "extra-files": [
        {
          "type": "json",
          "path": "tauri.conf.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
