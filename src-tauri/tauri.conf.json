{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "No Sleep Please",
  "version": "0.1.0",
  "identifier": "com.shoootyou.no-sleep-please",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; img-src 'self' asset: https://asset.localhost; connect-src ipc: http://ipc.localhost https://github.com https://api.github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Keep your computer awake and active",
    "publisher": "Rodolfo Castelo",
    "copyright": "Copyright (c) 2025 Rodolfo Castelo. MIT License.",
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/shoootyou/non-sleep-please/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDMzAyMDgyMzZEODhBMjAKUldRZ2l0ZzJnaUF3ekNRRFdjWlE3bFJQRkMzWUhCRTRVVzdzYWU0TmN1aFY1cmpTWjNVOXBya1YK"
    }
  }
}
