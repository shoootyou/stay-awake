{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Non-Sleep",
  "version": "0.1.0",
  "identifier": "com.rodolfo.non-sleep",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "Non-Sleep Settings",
        "url": "settings.html",
        "width": 480,
        "height": 580,
        "resizable": false,
        "visible": false,
        "center": true,
        "decorations": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Non-Sleep — Inactive"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Keep your computer awake and active",
    "copyright": "Copyright © 2026 Rodolfo. MIT License."
  }
}
